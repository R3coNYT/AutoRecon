# AutoRecon — environment variables

SHODAN_API_KEY=

# ── AI ──────────────────────────────────────────────────────────────────
# Set ENABLE_AI=true to let ChatGPT drive the entire reconnaissance scan.
# When enabled, the AI engine replaces the standard scan pipeline:
#   1. AutoRecon discovers all tools available on this machine
#   2. ChatGPT receives the target, tool list and its mission
#   3. ChatGPT generates an action plan and issues commands one by one
#   4. AutoRecon executes each command locally and returns the output
#   5. ChatGPT analyses results, adapts, and decides next steps
#   6. At the end, ChatGPT produces a full report with findings,
#      interpretations, remediations and a list of additional tools
#      that would allow deeper analysis.
ENABLE_AI=false
OPENAI_API_KEY=
# Optional — change model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o
